PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# NetSuite account
NETSUITE_ACCOUNT_ID=TD3063882
NETSUITE_REALM=TD3063882
NETSUITE_REST_BASE_URL=https://td3063882.suitetalk.api.netsuite.com

# Use tba for Token-Based Authentication, or oauth2 for OAuth 2.0.
NETSUITE_AUTH_MODE=tba

# Token-Based Authentication
NETSUITE_TBA_CONSUMER_KEY=replace-with-consumer-key
NETSUITE_TBA_CONSUMER_SECRET=replace-with-consumer-secret
NETSUITE_TBA_TOKEN_ID=replace-with-token-id
NETSUITE_TBA_TOKEN_SECRET=replace-with-token-secret

# OAuth 2.0, optional if NETSUITE_AUTH_MODE=oauth2.
NETSUITE_OAUTH2_ACCESS_TOKEN=
NETSUITE_OAUTH2_CLIENT_ID=
NETSUITE_OAUTH2_CLIENT_SECRET=
NETSUITE_OAUTH2_TOKEN_URL=
NETSUITE_OAUTH2_SCOPE=
NETSUITE_OAUTH2_GRANT_TYPE=client_credentials
NETSUITE_OAUTH2_CLIENT_ASSERTION=
NETSUITE_OAUTH2_CLIENT_ASSERTION_TYPE=urn:ietf:params:oauth:client-assertion-type:jwt-bearer
